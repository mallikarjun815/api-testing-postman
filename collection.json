              ]
            }
          },
          "response": []
        },
        {
          "name": "Get User Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = pm.response.json();\r",
                  "\r",
                  "// 42\r",
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));\r",
                  "\r",
                  "// 43\r",
                  "pm.test(\"Carts array exists\", () => pm.expect(jsonData.carts).to.be.an(\"array\"));\r",
                  "\r",
                  "// 44\r",
                  "pm.test(\"Carts not empty\", () => pm.expect(jsonData.carts.length).to.be.above(0));\r",
                  "\r",
                  "// Loop carts\r",
                  "jsonData.carts.forEach((cart, index) => {\r",
                  "\r",
                  "    // 45\r",
                  "    pm.test(`Cart ${index} has id`, () => pm.expect(cart.id).to.exist);\r",
                  "\r",
                  "    // 46\r",
                  "    pm.test(`Cart ${index} has userId`, () => pm.expect(cart.userId).to.exist);\r",
                  "\r",
                  "    // 47\r",
                  "    pm.test(`Cart ${index} products exist`, () => pm.expect(cart.products.length).to.be.above(0));\r",
                  "\r",
                  "    // 48\r",
                  "    pm.test(`Cart ${index} total > 0`, () => pm.expect(cart.total).to.be.above(0));\r",
                  "\r",
                  "    // 49\r",
                  "    pm.test(`Cart ${index} discounted total valid`, () => pm.expect(cart.discountedTotal).to.be.below(cart.total));\r",
                  "\r",
                  "    // 50\r",
                  "    pm.test(`Cart ${index} totalQuantity > 0`, () => pm.expect(cart.totalQuantity).to.be.above(0));\r",
                  "\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
